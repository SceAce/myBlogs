---
import { getEntry } from "astro:content";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

type FriendItem = {
	name: string;
	description: string;
	url: string;
	host: string;
	badge: string;
	hue: number;
};

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("Friends page content not found");
}

function parseFriendRows(body: string): FriendItem[] {
	return body
		.split("\n")
		.map((line) => line.trim())
		.filter(
			(line) =>
				line.startsWith("|") &&
				!line.includes("---") &&
				!line.toLowerCase().includes("| name "),
		)
		.map((line, index) => {
			const cells = line
				.split("|")
				.slice(1, -1)
				.map((cell) => cell.trim());

			const linkCell = cells[0] || "";
			const description = (cells[1] || "").replace(/<[^>]+>/g, "").trim();
			const urlMatch = linkCell.match(/href=['"]([^'"]+)['"]/i);
			const nameMatch = linkCell.match(/>([^<]+)</);
			const url = urlMatch?.[1] || "#";
			const name = nameMatch?.[1]?.trim() || `Friend ${index + 1}`;

			let host = url;
			try {
				host = new URL(url).hostname.replace(/^www\./, "");
			} catch {
				host = url.replace(/^https?:\/\//, "");
			}

			const badge = Array.from(name).slice(0, 2).join("").toUpperCase();
			const hueSeed = Array.from(host).reduce(
				(total, char) => total + char.charCodeAt(0),
				0,
			);

			return {
				name,
				description,
				url,
				host,
				badge,
				hue: 18 + ((hueSeed + index * 31) % 300),
			};
		});
}

const friends = parseFriendRows(friendsPost.body);
---

<MainGridLayout title={i18n(I18nKey.friends)} description={i18n(I18nKey.friends)}>
	<div class="flex flex-col w-full gap-4">
		<section class="friends-console card-base p-6 md:p-8">
			<div class="friends-console__header">
				<div>
					<p class="friends-console__eyebrow">Friends</p>
					<h1 class="friends-console__title">欢迎来到我的友链交换区</h1>
				</div>
				<div class="friends-console__status">ONLINE</div>
			</div>

			<div class="friends-console__screen">
				<div class="friends-console__line">[ 0.000001 ] booting friendship.exchange ... done</div>
				<div class="friends-console__line">[ 0.000187 ] loaded peers: {friends.length}</div>
				<div class="friends-console__line">[ 0.000451 ] manifest: clean content / long-term updates / mutual respect</div>
				<div class="friends-console__divider"></div>
				<div class="friends-console__line">[ 0.001001 ] 这里放的是我常看、会回访、愿意长期互相链接的朋友。</div>
				<div class="friends-console__line">[ 0.001245 ] 如果你也希望交换友链，可以直接把站点信息发给我。</div>
				<div class="friends-console__line">[ 0.001556 ] preferred signal: name / url / short intro / avatar</div>
			</div>
		</section>

		<section class="friends-grid">
			{friends.map((friend, index) => (
				<a
					href={friend.url}
					target="_blank"
					rel="noopener noreferrer"
					class="friend-card onload-animation"
					style={`--friend-hue: ${friend.hue}; animation-delay: calc(var(--content-delay) + ${index * 45}ms);`}
				>
					<div class="friend-card__badge">{friend.badge}</div>
					<div class="friend-card__body">
						<div class="friend-card__meta">
							<h2>{friend.name}</h2>
						</div>
						<p>{friend.description}</p>
					</div>
				</a>
			))}
		</section>
	</div>
</MainGridLayout>

<style>
	.friends-console {
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at top left, rgba(238, 119, 82, 0.14), transparent 30%),
			radial-gradient(circle at top right, rgba(231, 60, 126, 0.12), transparent 24%),
			linear-gradient(180deg, rgba(11, 18, 32, 0.95), rgba(16, 28, 42, 0.9));
	}

	.friends-console__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.friends-console__eyebrow {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(148, 163, 184, 0.8);
	}

	.friends-console__title {
		margin: 0.35rem 0 0;
		font-size: clamp(1.9rem, 3vw, 2.6rem);
		line-height: 1.15;
		color: rgba(248, 250, 252, 0.96);
	}

	.friends-console__status {
		flex-shrink: 0;
		padding: 0.45rem 0.75rem;
		border-radius: 999px;
		border: 1px solid rgba(125, 211, 252, 0.25);
		background: rgba(14, 165, 233, 0.12);
		color: rgba(186, 230, 253, 0.92);
		font-size: 0.78rem;
		letter-spacing: 0.14em;
	}

	.friends-console__screen {
		padding: 1.25rem 1.1rem;
		border-radius: 1rem;
		background:
			linear-gradient(180deg, rgba(235, 239, 245, 0.98), rgba(221, 228, 237, 0.96));
		font-family: "JetBrains Mono Variable", monospace;
		font-size: 0.9rem;
		line-height: 1.9;
		color: rgba(30, 41, 59, 0.92);
	}

	.friends-console__line {
		word-break: break-word;
	}

	.friends-console__divider {
		height: 1px;
		margin: 0.45rem 0 0.8rem;
		background: linear-gradient(90deg, transparent, rgba(100, 116, 139, 0.4), transparent);
	}

	.friends-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.friend-card {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem;
		border-radius: 1rem;
		text-decoration: none;
		border: 1px solid color-mix(in oklab, oklch(0.75 0.1 var(--friend-hue)) 22%, transparent);
		background:
			linear-gradient(160deg, color-mix(in oklab, oklch(0.72 0.09 var(--friend-hue)) 14%, transparent), transparent 55%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.015));
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease,
			background 0.18s ease;
	}

	.friend-card:hover {
		transform: translateY(-4px);
		border-color: color-mix(in oklab, oklch(0.78 0.12 var(--friend-hue)) 48%, transparent);
		box-shadow: 0 16px 36px rgba(15, 23, 42, 0.18);
	}

	.friend-card__badge {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 1rem;
		background:
			linear-gradient(135deg, oklch(0.76 0.12 var(--friend-hue)), oklch(0.58 0.11 var(--friend-hue)));
		color: white;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
	}

	.friend-card__body {
		min-width: 0;
	}

	.friend-card__meta {
		display: flex;
		align-items: baseline;
		margin-bottom: 0.35rem;
	}

	.friend-card__meta h2 {
		margin: 0;
		font-size: 1.05rem;
		color: rgba(248, 250, 252, 0.96);
	}

	.friend-card p {
		margin: 0;
		line-height: 1.7;
		color: rgba(226, 232, 240, 0.8);
	}

	:global(html:not(.dark)) .friends-console {
		border-color: rgba(15, 23, 42, 0.08);
		background:
			radial-gradient(circle at top left, rgba(245, 158, 11, 0.14), transparent 28%),
			radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 24%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(241, 245, 249, 0.96));
	}

	:global(html:not(.dark)) .friends-console__title {
		color: rgba(15, 23, 42, 0.92);
	}

	:global(html:not(.dark)) .friends-console__screen {
		background: linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(226, 232, 240, 0.95));
		color: rgba(15, 23, 42, 0.86);
	}

	:global(html:not(.dark)) .friend-card {
		border-color: color-mix(in oklab, oklch(0.72 0.09 var(--friend-hue)) 18%, rgba(15, 23, 42, 0.08));
		background:
			linear-gradient(160deg, color-mix(in oklab, oklch(0.82 0.08 var(--friend-hue)) 20%, transparent), rgba(255, 255, 255, 0.88) 60%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(248, 250, 252, 0.92));
		box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
	}

	:global(html:not(.dark)) .friend-card__meta h2 {
		color: rgba(15, 23, 42, 0.92);
	}

	:global(html:not(.dark)) .friend-card p {
		color: rgba(51, 65, 85, 0.82);
	}

	@media (max-width: 768px) {
		.friends-console__header {
			flex-direction: column;
		}

		.friend-card__meta {
			align-items: flex-start;
		}
	}
</style>
