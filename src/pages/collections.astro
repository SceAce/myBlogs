---
import { collectionsData } from "@/content/spec/collections";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
---

<MainGridLayout title="Collections" description="My manual collections">
  <div class="flex flex-col w-full gap-4">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-9 py-6 relative w-full hero-section">
        <h1 class="text-3xl font-bold mb-2">Collections</h1>
        <p class="text-sm text-gray-500 dark:text-gray-300">
          这里记录一些我读过、听过、玩过，或者单纯想收藏的东西。
        </p>
      </div>
    </div>

    {
      collectionsData.books.length > 0 && (
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative section-books">
          <div class="card-base z-10 px-9 py-6 relative w-full">
            <h2 class="text-2xl font-bold mb-6 section-title">📚 书籍</h2>
            <div class="grid gap-4">
              {collectionsData.books.map((item) => (
                <article class="collection-card">
                  <div class="flex flex-col gap-2">
                    {item.link ? (
                      <a
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xl font-semibold collection-title"
                      >
                        {item.title}
                      </a>
                    ) : (
                      <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                    )}

                    {item.subtitle && (
                      <p class="collection-subtitle">{item.subtitle}</p>
                    )}

                    {item.note && <p class="collection-note">{item.note}</p>}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      collectionsData.music.length > 0 && (
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative section-music">
          <div class="card-base z-10 px-9 py-6 relative w-full">
            <h2 class="text-2xl font-bold mb-6 section-title">🎵 音乐</h2>
            <div class="grid gap-4">
              {collectionsData.music.map((item) => (
                <article class="collection-card">
                  <div class="flex flex-col gap-2">
                    {item.link ? (
                      <a
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xl font-semibold collection-title"
                      >
                        {item.title}
                      </a>
                    ) : (
                      <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                    )}

                    {item.subtitle && (
                      <p class="collection-subtitle">{item.subtitle}</p>
                    )}

                    {item.note && <p class="collection-note">{item.note}</p>}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      collectionsData.games.length > 0 && (
        <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative section-games">
          <div class="card-base z-10 px-9 py-6 relative w-full">
            <h2 class="text-2xl font-bold mb-6 section-title">🎮 游戏</h2>
            <div class="grid gap-4">
              {collectionsData.games.map((item) => (
                <article class="collection-card">
                  <div class="flex flex-col gap-2">
                    {item.link ? (
                      <a
                        href={item.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xl font-semibold collection-title"
                      >
                        {item.title}
                      </a>
                    ) : (
                      <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                    )}

                    {item.subtitle && (
                      <p class="collection-subtitle">{item.subtitle}</p>
                    )}

                    {item.note && <p class="collection-note">{item.note}</p>}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      )
    }
  </div>
</MainGridLayout>

<style>
  .hero-section {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)),
      rgba(255, 255, 255, 0.015);
  }

  .section-books,
  .section-music,
  .section-games {
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .section-books .card-base {
    background:
      linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(251, 191, 36, 0.04)),
      rgba(255, 255, 255, 0.02);
  }

  .section-music .card-base {
    background:
      linear-gradient(135deg, rgba(168, 85, 247, 0.12), rgba(236, 72, 153, 0.04)),
      rgba(255, 255, 255, 0.02);
  }

  .section-games .card-base {
    background:
      linear-gradient(135deg, rgba(59, 130, 246, 0.12), rgba(34, 211, 238, 0.04)),
      rgba(255, 255, 255, 0.02);
  }

  .section-title {
    letter-spacing: 0.02em;
  }

  .section-books .section-title {
    color: rgb(245 158 11);
  }

  .section-music .section-title {
    color: rgb(192 132 252);
  }

  .section-games .section-title {
    color: rgb(56 189 248);
  }

  .collection-card {
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      background 0.18s ease;
    backdrop-filter: blur(8px);
  }

  .section-books .collection-card {
    border: 1px solid rgba(245, 158, 11, 0.2);
    background: linear-gradient(
      180deg,
      rgba(245, 158, 11, 0.08),
      rgba(255, 255, 255, 0.02)
    );
  }

  .section-music .collection-card {
    border: 1px solid rgba(168, 85, 247, 0.2);
    background: linear-gradient(
      180deg,
      rgba(168, 85, 247, 0.08),
      rgba(255, 255, 255, 0.02)
    );
  }

  .section-games .collection-card {
    border: 1px solid rgba(59, 130, 246, 0.2);
    background: linear-gradient(
      180deg,
      rgba(59, 130, 246, 0.08),
      rgba(255, 255, 255, 0.02)
    );
  }

  .collection-card:hover {
    transform: translateY(-3px);
  }

  .section-books .collection-card:hover {
    border-color: rgba(245, 158, 11, 0.45);
    box-shadow: 0 10px 30px rgba(245, 158, 11, 0.12);
  }

  .section-music .collection-card:hover {
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: 0 10px 30px rgba(168, 85, 247, 0.12);
  }

  .section-games .collection-card:hover {
    border-color: rgba(59, 130, 246, 0.45);
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.12);
  }

  .collection-title {
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .section-books .collection-title {
    color: rgb(255 236 179);
  }

  .section-music .collection-title {
    color: rgb(245 208 254);
  }

  .section-games .collection-title {
    color: rgb(186 230 253);
  }

  .collection-title:hover {
    text-decoration: underline;
  }

  .collection-subtitle {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .collection-note {
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }
</style>
