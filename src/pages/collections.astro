---
import { collectionsData } from "@/content/spec/collections";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

const sections = [
	{
		key: "books",
		title: "书籍",
		icon: "📚",
		accent: "amber",
		items: collectionsData.books,
	},
	{
		key: "music",
		title: "音乐",
		icon: "🎵",
		accent: "rose",
		items: collectionsData.music,
	},
	{
		key: "games",
		title: "游戏",
		icon: "🎮",
		accent: "sky",
		items: collectionsData.games,
	},
].filter((section) => section.items.length > 0);
---

<MainGridLayout title="Collections" description="My manual collections">
	<div class="collections-page">
		<section class="collections-hero card-base">
			<p class="collections-hero__eyebrow">Collections</p>
			<h1>一些留下来的东西</h1>
			<p>
				这里记录我想长期保留的书、音乐和游戏。它们不一定最重要，但都在某个阶段陪过我一段时间。
			</p>
		</section>

		{sections.map((section) => (
			<section class={`collection-section collection-section--${section.accent}`}>
				<div class="collection-section__header">
					<h2>
						<span>{section.icon}</span>
						{section.title}
					</h2>
					<div class="collection-section__count">{section.items.length} items</div>
				</div>

				<div class="collection-grid">
					{section.items.map((item, index) => (
						<article
							class="collection-item onload-animation"
							style={`animation-delay: calc(var(--content-delay) + ${index * 40}ms);`}
						>
							<div class="collection-item__top">
								{item.link ? (
									<a
										href={item.link}
										target="_blank"
										rel="noopener noreferrer"
										class="collection-item__title"
									>
										{item.title}
									</a>
								) : (
									<h3 class="collection-item__title collection-item__title--plain">
										{item.title}
									</h3>
								)}

								{item.subtitle && <p class="collection-item__subtitle">{item.subtitle}</p>}
							</div>

							{item.note && <p class="collection-item__note">{item.note}</p>}
						</article>
					))}
				</div>
			</section>
		))}
	</div>
</MainGridLayout>

<style>
	.collections-page {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.collections-hero {
		padding: 2rem 2.25rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			radial-gradient(circle at top left, rgba(245, 158, 11, 0.14), transparent 28%),
			radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 24%),
			linear-gradient(180deg, rgba(26, 35, 49, 0.88), rgba(18, 24, 37, 0.92));
		box-shadow: 0 12px 36px rgba(2, 6, 23, 0.12);
	}

	.collections-hero__eyebrow {
		margin: 0 0 0.6rem;
		font-size: 0.78rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(148, 163, 184, 0.82);
	}

	.collections-hero h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 3vw, 2.7rem);
		line-height: 1.1;
	}

	.collections-hero p:last-child {
		margin: 0;
		max-width: 42rem;
		line-height: 1.8;
		color: rgba(226, 232, 240, 0.84);
	}

	.collection-section {
		padding: 1.4rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.07);
		background:
			radial-gradient(circle at top right, rgba(255, 255, 255, 0.035), transparent 32%),
			linear-gradient(180deg, rgba(18, 25, 37, 0.88), rgba(12, 18, 30, 0.92));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.collection-section__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.collection-section__header h2 {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		margin: 0;
		font-size: 1.35rem;
		color: rgba(248, 250, 252, 0.92);
	}

	.collection-section__count {
		padding: 0.4rem 0.7rem;
		border-radius: 999px;
		font-size: 0.76rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: rgba(255, 255, 255, 0.08);
		color: rgba(226, 232, 240, 0.8);
	}

	.collection-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.collection-item {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		min-height: 11.5rem;
		padding: 1rem 1rem 1.1rem;
		border-radius: 1rem;
		backdrop-filter: blur(10px);
		box-shadow: 0 10px 24px rgba(2, 6, 23, 0.1);
		transition:
			transform 0.18s ease,
			border-color 0.18s ease,
			box-shadow 0.18s ease,
			background 0.18s ease;
	}

	.collection-item:hover {
		transform: translateY(-4px);
	}

	.collection-item__top {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	.collection-item__title {
		display: inline-block;
		margin: 0;
		font-size: 1.05rem;
		font-weight: 700;
		text-decoration: none;
	}

	.collection-item__title:hover {
		text-decoration: underline;
	}

	.collection-item__title--plain:hover {
		text-decoration: none;
	}

	.collection-item__subtitle {
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.5;
		color: rgba(226, 232, 240, 0.78);
	}

	.collection-item__note {
		margin: 1rem 0 0;
		line-height: 1.8;
		color: rgba(241, 245, 249, 0.88);
	}

	.collection-section--amber .collection-item {
		border: 1px solid rgba(245, 158, 11, 0.16);
		background:
			radial-gradient(circle at top right, rgba(251, 191, 36, 0.08), transparent 35%),
			linear-gradient(180deg, rgba(45, 32, 21, 0.9), rgba(28, 24, 22, 0.94));
	}

	.collection-section--amber .collection-item:hover {
		border-color: rgba(251, 191, 36, 0.32);
		box-shadow: 0 14px 28px rgba(245, 158, 11, 0.12);
		background:
			radial-gradient(circle at top right, rgba(251, 191, 36, 0.12), transparent 35%),
			linear-gradient(180deg, rgba(53, 36, 22, 0.92), rgba(34, 27, 23, 0.96));
	}

	.collection-section--amber .collection-item__title {
		color: rgb(253 230 138);
	}

	.collection-section--rose .collection-item {
		border: 1px solid rgba(244, 114, 182, 0.16);
		background:
			radial-gradient(circle at top right, rgba(244, 114, 182, 0.08), transparent 35%),
			linear-gradient(180deg, rgba(44, 24, 34, 0.9), rgba(29, 20, 28, 0.94));
	}

	.collection-section--rose .collection-item:hover {
		border-color: rgba(244, 114, 182, 0.32);
		box-shadow: 0 14px 28px rgba(244, 114, 182, 0.12);
		background:
			radial-gradient(circle at top right, rgba(244, 114, 182, 0.12), transparent 35%),
			linear-gradient(180deg, rgba(50, 25, 38, 0.92), rgba(33, 21, 30, 0.96));
	}

	.collection-section--rose .collection-item__title {
		color: rgb(251 207 232);
	}

	.collection-section--sky .collection-item {
		border: 1px solid rgba(56, 189, 248, 0.16);
		background:
			radial-gradient(circle at top right, rgba(56, 189, 248, 0.08), transparent 35%),
			linear-gradient(180deg, rgba(21, 34, 44, 0.9), rgba(18, 23, 31, 0.94));
	}

	.collection-section--sky .collection-item:hover {
		border-color: rgba(56, 189, 248, 0.32);
		box-shadow: 0 14px 28px rgba(56, 189, 248, 0.12);
		background:
			radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 35%),
			linear-gradient(180deg, rgba(23, 40, 52, 0.92), rgba(18, 26, 35, 0.96));
	}

	.collection-section--sky .collection-item__title {
		color: rgb(186 230 253);
	}

	:global(html:not(.dark)) .collections-hero {
		border-color: rgba(15, 23, 42, 0.08);
		background:
			radial-gradient(circle at top left, rgba(245, 158, 11, 0.14), transparent 28%),
			radial-gradient(circle at top right, rgba(14, 165, 233, 0.12), transparent 24%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.96));
	}

	:global(html:not(.dark)) .collections-hero p:last-child {
		color: rgba(51, 65, 85, 0.78);
	}

	:global(html:not(.dark)) .collection-section {
		border-color: rgba(15, 23, 42, 0.08);
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(248, 250, 252, 0.9));
	}

	:global(html:not(.dark)) .collection-section__count {
		background: rgba(15, 23, 42, 0.05);
		color: rgba(51, 65, 85, 0.68);
	}

	:global(html:not(.dark)) .collection-item__subtitle {
		color: rgba(51, 65, 85, 0.72);
	}

	:global(html:not(.dark)) .collection-item__note {
		color: rgba(15, 23, 42, 0.82);
	}

	:global(html:not(.dark)) .collection-section--amber .collection-item {
		border-color: rgba(245, 158, 11, 0.22);
		background: linear-gradient(180deg, rgba(255, 237, 213, 0.95), rgba(255, 255, 255, 0.98));
	}

	:global(html:not(.dark)) .collection-section--amber .collection-item__title {
		color: rgb(180 83 9);
	}

	:global(html:not(.dark)) .collection-section--rose .collection-item {
		border-color: rgba(244, 114, 182, 0.22);
		background: linear-gradient(180deg, rgba(252, 231, 243, 0.95), rgba(255, 255, 255, 0.98));
	}

	:global(html:not(.dark)) .collection-section--rose .collection-item__title {
		color: rgb(190 24 93);
	}

	:global(html:not(.dark)) .collection-section--sky .collection-item {
		border-color: rgba(56, 189, 248, 0.22);
		background: linear-gradient(180deg, rgba(224, 242, 254, 0.95), rgba(255, 255, 255, 0.98));
	}

	:global(html:not(.dark)) .collection-section--sky .collection-item__title {
		color: rgb(3 105 161);
	}

	@media (max-width: 768px) {
		.collections-hero {
			padding: 1.5rem;
		}

		.collection-section {
			padding: 1rem;
		}

		.collection-section__header {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
