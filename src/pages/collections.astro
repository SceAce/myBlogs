---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { collectionsData } from "@/content/spec/collections";
---

<MainGridLayout title={"Collections"} description={"My manual collections"}>
  <div class="flex flex-col w-full gap-4">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-9 py-6 relative w-full">
        <h1 class="text-3xl font-bold mb-2">Collections</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          这里记录一些我读过、听过、玩过，或者单纯想收藏的东西。
        </p>
      </div>
    </div>

    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-9 py-6 relative w-full">
        <h2 class="text-2xl font-bold mb-6">书籍</h2>
        <div class="grid gap-4">
          {collectionsData.books.map((item) => (
            <article class="collection-card">
              <div class="flex flex-col gap-2">
                {item.link ? (
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xl font-semibold collection-title"
                  >
                    {item.title}
                  </a>
                ) : (
                  <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                )}

                {item.subtitle && (
                  <p class="text-sm text-gray-500 dark:text-gray-400">{item.subtitle}</p>
                )}

                {item.note && <p class="collection-note">{item.note}</p>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-9 py-6 relative w-full">
        <h2 class="text-2xl font-bold mb-6">音乐</h2>
        <div class="grid gap-4">
          {collectionsData.music.map((item) => (
            <article class="collection-card">
              <div class="flex flex-col gap-2">
                {item.link ? (
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xl font-semibold collection-title"
                  >
                    {item.title}
                  </a>
                ) : (
                  <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                )}

                {item.subtitle && (
                  <p class="text-sm text-gray-500 dark:text-gray-400">{item.subtitle}</p>
                )}

                {item.note && <p class="collection-note">{item.note}</p>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative">
      <div class="card-base z-10 px-9 py-6 relative w-full">
        <h2 class="text-2xl font-bold mb-6">游戏</h2>
        <div class="grid gap-4">
          {collectionsData.games.map((item) => (
            <article class="collection-card">
              <div class="flex flex-col gap-2">
                {item.link ? (
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xl font-semibold collection-title"
                  >
                    {item.title}
                  </a>
                ) : (
                  <h3 class="text-xl font-semibold collection-title">{item.title}</h3>
                )}

                {item.subtitle && (
                  <p class="text-sm text-gray-500 dark:text-gray-400">{item.subtitle}</p>
                )}

                {item.note && <p class="collection-note">{item.note}</p>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</MainGridLayout>

<style>
  .collection-card {
    border: 1px solid rgba(127, 127, 127, 0.15);
    border-radius: 1rem;
    padding: 1rem 1.1rem;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .collection-card:hover {
    transform: translateY(-2px);
    border-color: rgba(127, 127, 127, 0.3);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .collection-title {
    text-decoration: none;
  }

  .collection-title:hover {
    text-decoration: underline;
  }

  .collection-note {
    line-height: 1.75;
  }
</style>
