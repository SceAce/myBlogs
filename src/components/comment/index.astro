---
import type { CollectionEntry } from "astro:content";
import { commentConfig } from "@/config";
import Giscus from "./Giscus.svelte";

interface Props {
	post: CollectionEntry<"posts">;
}

const showGiscus = commentConfig?.enabled && !!commentConfig?.giscus;
const notice = commentConfig?.notice;
---

{showGiscus && (
    <div class="card-base p-6 mb-4">
        <Giscus client:only="svelte" />
    </div>
)}

{!showGiscus && notice && (
    <div class="card-base p-6 mb-4">
        <div class="flex flex-col gap-3">
            <div>
                <div class="text-lg font-bold text-90">{notice.title}</div>
                <p class="text-sm text-50 mt-2">{notice.description}</p>
            </div>
            {notice.linkUrl && notice.linkText && (
                <div>
                    <a
                        href={notice.linkUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-regular rounded-lg px-4 h-10 inline-flex active:scale-95"
                    >
                        {notice.linkText}
                    </a>
                </div>
            )}
        </div>
    </div>
)}
